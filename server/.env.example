# MongoDB Atlas Connection (Cloud Database)
# Database: FOOTBRAIN
# Collection: users
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/FOOTBRAIN?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/FOOTBRAIN?retryWrites=true&w=majority

# JWT Secret (change this to a random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=3000

# Admin Credentials (will be created on first run)
ADMIN_EMAIL=admin@footbrain.com
ADMIN_PASSWORD=admin123

# Python AI API URL (for market value predictions)
PYTHON_API_URL=http://localhost:5000
